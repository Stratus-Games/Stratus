{
  "name": "scramjet-proxy-browser",
  "version": "1.0.0",
  "private": true,
  "description": "Local Scramjet proxy browser starter for VS Code on Windows",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/prepare-static.mjs && node scripts/generate-config.mjs",
    "start": "node src/index.js",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "@fastify/static": "^8.2.0",
    "@mercuryworkshop/bare-mux": "^2.1.8",
    "@mercuryworkshop/libcurl-transport": "^2.0.5",
    "@mercuryworkshop/scramjet": "https://github.com/MercuryWorkshop/scramjet/releases/download/latest/mercuryworkshop-scramjet-2.0.0-alpha.tgz",
    "@mercuryworkshop/wisp-js": "^0.4.1",
    "fastify": "^5.4.0"
  }
}
